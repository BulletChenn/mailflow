# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Random base64 string used to encrypt local storage (generate with: openssl rand -base64 32)
STORAGE_KEY=your-random-base64-storage-key

# Azure app registration — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
OUTLOOK_CLIENT_ID=your-azure-app-client-id
OUTLOOK_CLIENT_SECRET=your-azure-app-client-secret
OUTLOOK_REDIRECT_URI=http://localhost:3000/api/auth/callback
